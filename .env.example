# Copy to .env (git-ignored) and fill in. Compose injects these into every
# app container; the code reads env vars first, host-file fallbacks second.

# Databento (free polling still quotes cost before every pull)
DATABENTO_API_KEY=db-xxxxxxxxxxxxxxxxxxxxxxxxx

# Tradovate — demo_loop only places orders when TRADOVATE_ENV=demo
# (going live additionally requires editing ALLOW_LIVE in
#  engine/execution/tradovate_client.py — deliberately not a config flag)
TRADOVATE_ENV=demo
TRADOVATE_NAME=your_username
TRADOVATE_PASSWORD=your_password
TRADOVATE_CID=12345
TRADOVATE_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
TRADOVATE_APP_ID=QuantReal

# Stack knobs
KRONOS_INSTRUMENT=M6EU6
L3_INSTRUMENT=M6E.FUT
QR_INSTRUMENT=M6EU6
QR_BAR_SIZE=250
